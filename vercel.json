{
  "version": 2,
  "routes": [
    { "src": "/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/api/(.*)",  "dest": "/api/index.js" },
    { "src": "/css/(.*)",  "dest": "/css/$1" },
    { "src": "/js/(.*)",   "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/docs.html", "dest": "/docs.html" },
    { "src": "/checkout.html", "dest": "/checkout.html" },
    { "src": "/",          "dest": "/index.html" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" }
  ]
}