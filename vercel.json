{
  "version": 2,
  "rewrites": [
    { "source": "/auth/:path*",  "destination": "/api/index.js" },
    { "source": "/api/:path*",   "destination": "/api/index.js" },
    { "source": "/tools/:path*", "destination": "/api/index.js" },
    { "source": "/dashboard",    "destination": "/dashboard.html" },
    { "source": "/docs",         "destination": "/docs.html" },
    { "source": "/checkout",     "destination": "/checkout.html" },
    { "source": "/",             "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/dashboard.html", "destination": "/dashboard", "permanent": true },
    { "source": "/docs.html",      "destination": "/docs",      "permanent": true },
    { "source": "/checkout.html",  "destination": "/checkout",  "permanent": true },
    { "source": "/index.html",     "destination": "/",          "permanent": true }
  ]
}